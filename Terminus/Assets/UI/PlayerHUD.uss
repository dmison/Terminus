:root {
}

.health {
    color: red;
}

.power {
    color: springgreen;
}

Label {
    font-size: 18px;
    -unity-font-style: bold;
    -unity-font-definition: resource("FlatSkin/Font/Roboto-ThinItalic");
}

.powerRow, .healthRow {
    flex-grow: 0; 
    flex-direction: row;
    background-color: rgba(0,0,0,0.8);

    justify-content: center; 
    align-self: flex-start;
    
    
    min-width: 130px;
    
}